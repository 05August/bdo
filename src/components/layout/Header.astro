---
import { t, type Lang } from "@/i18n";
import logo from "@/assets/images/logo.png";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const pathname = Astro.url.pathname;
const pathWithoutLocale = pathname.replace(/^\/[^/]+/, "") || "";
const currentPath = pathWithoutLocale.replace(/^\//, "") || "";

const base = (l: Lang, path = "") => (path ? `/${l}/${path}` : `/${l}`);
const urlVi = base("vi", currentPath);
const urlEn = base("en", currentPath);
const urlHome = base(lang);
const urlServices = base(lang, "services");
const urlIndustries = base(lang, "industries");
const urlAbout = base(lang, "about");
const urlContact = base(lang, "contact");
---

<header class="header">
  <input type="checkbox" id="nav-toggle" class="nav-toggle" />
  <div class="header-inner">
    <a href={urlHome} class="logo" aria-label={t(lang, "nav.home")}>
      <img src={logo.src} alt="NHC Accounting Consulting" class="logo-img" />
    </a>
    <label
      for="nav-toggle"
      class="mobile-toggle"
      aria-label="Toggle navigation"
    >
      <span class="mobile-toggle-icon"></span>
    </label>
    <nav class="nav">
      <a href={`${base(lang)}#services`} class="nav-link">
        {t(lang, "nav.services")}
      </a>
      <a href={`${base(lang)}#industries`} class="nav-link">
        {t(lang, "nav.industries")}
      </a>
      <a href={urlAbout} class="nav-link">{t(lang, "nav.about")}</a>
      <span class="locale-switcher">
        <a
          href={urlEn}
          class:list={["locale-link", { active: lang === "en" }]}
          aria-current={lang === "en" ? "page" : undefined}>EN</a
        >
        <span class="separator" aria-hidden="true">|</span>
        <a
          href={urlVi}
          class:list={["locale-link", { active: lang === "vi" }]}
          aria-current={lang === "vi" ? "page" : undefined}>VI</a
        >
      </span>
    </nav>
    <a href={urlContact} class="cta">{t(lang, "nav.contact")}</a>
  </div>
  <label for="nav-toggle" class="mobile-overlay" aria-hidden="true"></label>
  <div class="mobile-panel">
    <div class="mobile-panel-inner">
      <div class="mobile-panel-inner-header">
        <a href={urlHome} class="mobile-logo">
          <img src={logo.src} alt="NHC" class="logo-img" />
        </a>
        <label for="nav-toggle" class="mobile-close" aria-label="Close menu">
          <span class="mobile-close-icon"></span>
        </label>
      </div>

      <nav class="mobile-nav">
        <a
          href={`${base(lang)}#services`}
          class="mobile-nav-link"
        >
          {t(lang, "nav.services")}
        </a>
        <a
          href={`${base(lang)}#industries`}
          class="mobile-nav-link"
        >
          {t(lang, "nav.industries")}
        </a>
        <a href={urlAbout} class="mobile-nav-link">{t(lang, "nav.about")}</a>
        <span class="mobile-locale">
          <a
            href={urlEn}
            class:list={["mobile-locale-link", { active: lang === "en" }]}>EN</a
          >
          <span class="separator">|</span>
          <a
            href={urlVi}
            class:list={["mobile-locale-link", { active: lang === "vi" }]}>VI</a
          >
        </span>
        <a href={urlContact} class="mobile-cta">{t(lang, "nav.contact")}</a>
      </nav>
    </div>
  </div>
</header>

<script>
  if (typeof window !== "undefined") {
    window.addEventListener("DOMContentLoaded", () => {
      const isMobile = window.matchMedia("(max-width: 900px)").matches;
      if (!isMobile) return;

      const toggle = document.getElementById("nav-toggle") as
        | HTMLInputElement
        | null;
      if (!toggle) return;

      const root = document.documentElement;

      const setScrollLock = (locked: boolean) => {
        root.style.overflow = locked ? "hidden" : "";
      };

      const closeMenu = () => {
        if (!toggle.checked) return;
        toggle.checked = false;
        setScrollLock(false);
      };

      toggle.addEventListener("change", () => {
        setScrollLock(toggle.checked);
      });

      const selectors = [
        ".mobile-overlay",
        ".mobile-close",
        ".mobile-nav-link",
        ".mobile-cta",
        ".mobile-logo",
        ".mobile-locale-link",
      ];

      selectors.forEach((selector) => {
        document.querySelectorAll(selector).forEach((el) => {
          el.addEventListener("click", () => {
            closeMenu();
          });
        });
      });
    });
  }
</script>

<style>
  .header {
    background: #fff;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.08);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding-left: 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    position: relative;
  }
  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    padding: 0.75rem 0rem;
  }
  .logo-img {
    display: block;
    height: 48px;
    width: auto;
    object-fit: contain;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex: 1;
    justify-content: flex-end;
  }
  .nav-link {
    color: #333;
    text-decoration: none;
    font-size: 16px;
    font-weight: 700;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: #e81a3b;
  }
  .locale-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .locale-link {
    color: #333;
    text-decoration: none;
    font-size: 16px;
    font-weight: 700;
  }
  .locale-link:hover,
  .locale-link.active {
    color: #e81a3b;
  }
  .separator {
    color: #999;
    user-select: none;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1.25rem;
    background: #e81a3b;
    color: #fff;
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 0.04em;
    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
    height: 72px;
    width: 147px;
  }
  .cta:hover {
    background: #a01930;
    color: #fff;
  }
  .nav-toggle {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    width: 0;
    height: 0;
  }
  .mobile-toggle {
    display: none;
  }
  .mobile-toggle-icon,
  .mobile-toggle-icon::before,
  .mobile-toggle-icon::after {
    display: block;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: #333;
    position: relative;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }
  .mobile-toggle-icon::before,
  .mobile-toggle-icon::after {
    content: "";
    position: absolute;
    left: 0;
  }
  .mobile-toggle-icon::before {
    top: -6px;
  }
  .mobile-toggle-icon::after {
    top: 6px;
  }
  .mobile-overlay,
  .mobile-panel {
    display: none;
  }
  @media (max-width: 900px) {
    .header {
      position: relative;
    }
    .header-inner {
      padding-inline: 1rem;
      gap: 1rem;
    }
    .nav,
    .cta {
      display: none;
    }
    .mobile-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 999px;
      background: #fff;
      margin-left: auto;
      cursor: pointer;
    }
    .mobile-overlay {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.4);
      z-index: 98;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }
    .mobile-panel {
      display: block;
      position: fixed;
      top: 0;
      right: 0;
      width: 100%;
      height: 100%;
      background: #fff;
      z-index: 99;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      overflow-y: auto;
    }

    .mobile-panel-inner-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .mobile-panel-inner {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .mobile-close {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 999px;
      background: #fff;
      cursor: pointer;
    }
    .mobile-close-icon {
      display: block;
      width: 16px;
      height: 16px;
      position: relative;
    }
    .mobile-close-icon::before,
    .mobile-close-icon::after {
      content: "";
      position: absolute;
      left: 50%;
      top: 50%;
      width: 18px;
      height: 2px;
      background: #333;
      transform: translate(-50%, -50%) rotate(45deg);
    }
    .mobile-close-icon::after {
      transform: translate(-50%, -50%) rotate(-45deg);
    }
    .mobile-logo img {
      height: 48px;
      width: auto;
    }
    .mobile-nav {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .mobile-nav-link {
      color: #333;
      text-decoration: none;
      font-size: 1rem;
      font-weight: 500;
    }
    .mobile-nav-link:hover {
      color: #e81a3b;
    }
    .mobile-locale {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .mobile-locale-link {
      color: #333;
      text-decoration: none;
      font-weight: 500;
    }
    .mobile-locale-link.active {
      color: #e81a3b;
    }
    .mobile-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.75rem 1.5rem;
      background: #e81a3b;
      color: #fff;
      font-weight: 700;
      font-size: 0.875rem;
      letter-spacing: 0.04em;
      text-decoration: none;
      text-transform: uppercase;
      border-radius: 4px;
      align-self: flex-start;
    }
    .mobile-cta:hover {
      background: #a01930;
      color: #fff;
    }
    .nav-toggle:checked ~ .mobile-overlay {
      opacity: 1;
      pointer-events: auto;
    }
    .nav-toggle:checked ~ .mobile-panel {
      transform: translateX(0);
    }
    .nav-toggle:checked + .header-inner .mobile-toggle .mobile-toggle-icon {
      transform: rotate(45deg);
    }
    .nav-toggle:checked
      + .header-inner
      .mobile-toggle
      .mobile-toggle-icon::before {
      transform: rotate(-90deg);
      top: 0;
    }
    .nav-toggle:checked
      + .header-inner
      .mobile-toggle
      .mobile-toggle-icon::after {
      opacity: 0;
    }
  }
</style>
