---
import { t, type Lang } from "@/i18n";
import logo from "@/assets/images/logo.png";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const pathname = Astro.url.pathname;
const pathWithoutLocale = pathname.replace(/^\/[^/]+/, "") || "";
const currentPath = pathWithoutLocale.replace(/^\//, "") || "";

const base = (l: Lang, path = "") => (path ? `/${l}/${path}` : `/${l}`);
const urlVi = base("vi", currentPath);
const urlEn = base("en", currentPath);
const urlHome = base(lang);
const urlServices = base(lang, "services");
const urlIndustries = base(lang, "industries");
const urlAbout = base(lang, "about");
const urlContact = base(lang, "contact");
---

<footer class="footer" data-ktc-search-exclude="true" data-reactroot="">
  <div class="footer__container container">
    <div class="footer__left-container">
      <ul class="footer__menu">
        <li class="footer__menu-item">
          <div class="">
            <a
              href={urlContact}
              target=""
              title=""
              class="animated-link inline text-white hover:text-white"
              ><span class="hover-underline">{t(lang, "nav.contact")}</span></a
            >
          </div>
        </li><li class="footer__menu-item">
          <div class="">
            <a
              href={urlAbout}
              target=""
              title=""
              class="animated-link inline text-white hover:text-white"
              ><span class="hover-underline">{t(lang, "nav.about")}</span></a
            >
          </div>
        </li><li class="footer__menu-item">
          <div class="">
            <a
              href="#"
              target=""
              title=""
              class="animated-link inline text-white hover:text-white"
              ><span class="hover-underline"
                >{t(lang, "nav.privacy-policy")}</span
              ></a
            >
          </div>
        </li><li class="footer__menu-item">
          <div class="">
            <a
              href={urlHome}
              target=""
              title=""
              class="animated-link inline text-white hover:text-white"
              ><span class="hover-underline">{t(lang, "nav.home")}</span></a
            >
          </div>
        </li>
      </ul>
    </div><div class="footer__right-container">
      <div class="footer__subscribe-title">
        {t(lang, "footer.email-sign-up")}
      </div><div class="footer__subscribe-content">
        {t(lang, "footer.subscribe-content")}
      </div><a role="button" class="btn" href="#" target="_self" title=""
        ><span class="btn-text"
          ><span class="">{t(lang, "footer.subscribe")}</span></span
        ></a
      ><div class="footer__social-icons">
        <ul class="footer__social-menu">
          <li class="footer__social-item">
            <a
              class="footer__social-link"
              href="#"
              target="_blank"
              title="NHC in Vietnam (Opens in a new window/tab)"
              aria-label="NHC in Vietnam"
              ><svg
                width="48"
                height="48"
                viewBox="0 0 48 48"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                ><path
                  fill-rule="evenodd"
