                  fill="#E7E7E7"></path></svg
              ><span class="sr-only">Opens in a new window/tab</span></a
            >
          </li><li class="footer__social-item">
            <a
              class="footer__social-link"
              href="#"
              target="_blank"
              title="NHC in Vietnam (Opens in a new window/tab)"
              aria-label="NHC in Vietnam"
              ><svg
                width="48"
                height="48"
                viewBox="0 0 48 48"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                ><path
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                  d="M4 24C4 12.9543 12.9543 4 24 4C35.0457 4 44 12.9543 44 24C44 35.0457 35.0457 44 24 44C12.9543 44 4 35.0457 4 24Z"
                  fill="#404040"></path><path
                  fill-rule="evenodd"
