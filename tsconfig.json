{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "resolveJsonModule": true,
    "paths": {
      "@components/*": ["./src/components/*"],
      "@assets/*": ["./src/assets/*"],
      "@/*": ["./src/*"]
    },
    "baseUrl": ".",
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}
